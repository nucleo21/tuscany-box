<script>
window.addEventListener('scroll',()=>{
  document.getElementById('nav').style.background=window.scrollY>60?'rgba(3,8,15,.97)':'rgba(3,8,15,.88)';
});
const observer=new IntersectionObserver(entries=>{entries.forEach(e=>{if(e.isIntersecting)e.target.classList.add('visible')})},{threshold:.1});
document.querySelectorAll('.ing-card').forEach(el=>observer.observe(el));
// stars
const canvas=document.getElementById('star-canvas');
const ctx=canvas.getContext('2d');
function resize(){canvas.width=window.innerWidth;canvas.height=window.innerHeight}
resize();window.addEventListener('resize',resize);
const stars=Array.from({length:120},()=>({
  x:Math.random()*canvas.width,y:Math.random()*canvas.height,
  r:Math.random()*1.2+.2,speed:Math.random()*.003+.001,
  phase:Math.random()*Math.PI*2
}));
let t=0;
function drawStars(){
  ctx.clearRect(0,0,canvas.width,canvas.height);
  t+=0.016;
  stars.forEach(s=>{
    const op=.2+Math.sin(t*s.speed*60+s.phase)*.15;
    ctx.beginPath();ctx.arc(s.x,s.y,s.r,0,Math.PI*2);
    ctx.fillStyle=`rgba(200,220,255,${op})`;ctx.fill();
  });
  requestAnimationFrame(drawStars);
}
drawStars();
</script>
