.ing-origin{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--purple2);opacity:.8}
.ing-story{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;line-height:1.9;color:rgba(240,235,248,.62);margin-bottom:1.1rem}
.ing-note{font-size:.82rem;line-height:1.7;color:rgba(240,235,248,.42);padding:.9rem 1rem;background:rgba(123,94,167,.07);border-left:2px solid rgba(123,94,167,.3)}
