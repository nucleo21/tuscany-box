nav{background:rgba(12,8,16,.88);color:var(--panna)}
.nav-logo{color:var(--panna)}.nav-logo span{color:var(--purple2)}
.nav-links a{color:var(--panna)}.nav-links a:hover{color:var(--purple2)}
.nav-back{color:var(--panna)}

.hero{
  min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:120px 2rem 5rem;position:relative;overflow:hidden;
  background:radial-gradient(ellipse 70% 60% at 50% 50%,rgba(123,94,167,.14) 0%,transparent 70%),
             radial-gradient(ellipse 100% 40% at 50% 100%,rgba(80,50,130,.2) 0%,transparent 60%),
             linear-gradient(180deg,var(--bg) 0%,var(--bg2) 60%,var(--bg3) 100%);
}
/* floating mist */
.mist{position:absolute;border-radius:50%;pointer-events:none;animation:drift ease-in-out infinite;background:radial-gradient(ellipse,rgba(123,94,167,.08),transparent)}
@keyframes drift{0%,100%{transform:translateX(0) translateY(0)}33%{transform:translateX(30px) translateY(-20px)}66%{transform:translateX(-20px) translateY(15px)}}
.hero-dante{font-family:'Cormorant Garamond',serif;font-size:.82rem;font-style:italic;color:rgba(155,126,199,.7);letter-spacing:.18em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp .8s .1s ease forwards}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(3rem,9vw,8rem);line-height:.95;font-weight:700;color:var(--panna);opacity:0;animation:fadeUp .9s .2s ease forwards;letter-spacing:-.02em}
.hero-title em{font-style:italic;color:var(--purple2);display:block;font-size:.5em}
.hero-sub{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:300;line-height:1.9;color:var(--grigio);max-width:520px;margin:1.5rem auto 2.5rem;opacity:0;animation:fadeUp .9s .35s ease forwards}
.hero-quote{font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;color:rgba(123,94,167,.6);margin-bottom:2.5rem;opacity:0;animation:fadeUp .9s .5s ease forwards}
.btn-order{background:var(--purple);color:var(--panna);border:none;padding:1rem 2.8rem;font-family:'Jost',sans-serif;font-size:.82rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;cursor:pointer;transition:all .35s;text-decoration:none;display:inline-block;opacity:0;animation:fadeUp .9s .65s ease forwards}
.btn-order:hover{background:var(--purple2);transform:translateY(-3px);box-shadow:0 12px 30px rgba(123,94,167,.4)}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}
.divider{display:flex;align-items:center;justify-content:center;gap:1rem;padding:2rem;font-size:1.4rem;opacity:.4}
.div-line{flex:1;max-width:200px;height:1px;background:linear-gradient(90deg,transparent,var(--purple-dim),transparent)}
.ingredients-section{max-width:1000px;margin:0 auto;padding:4rem 2rem 6rem}
.ing-header-section{text-align:center;margin-bottom:3rem}
.ing-tag{font-size:.64rem;letter-spacing:.3em;text-transform:uppercase;color:var(--purple2);font-weight:500;margin-bottom:.8rem;display:flex;align-items:center;justify-content:center;gap:.8rem}
.ing-tag::before,.ing-tag::after{content:'';width:24px;height:1px;background:var(--purple-dim);display:block}
.ing-section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:600;color:var(--panna);line-height:1.15}
.ing-section-title em{font-style:italic;color:var(--purple2)}
.ing-section-desc{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--grigio);margin-top:.8rem;font-weight:300;line-height:1.8}
.ing-grid{display:flex;flex-direction:column;gap:1.2rem}
.ing-card{background:rgba(19,15,26,.7);border:1px solid rgba(123,94,167,.15);border-left:3px solid var(--purple);padding:1.8rem 2rem;opacity:0;transform:translateY(20px);transition:opacity .6s ease,transform .6s ease,border-color .3s,background .3s;transition-delay:var(--delay)}
.ing-card.visible{opacity:1;transform:translateY(0)}
.ing-card:hover{background:rgba(28,21,38,.8);border-left-color:var(--purple2)}
.ing-header{display:flex;align-items:center;gap:1rem;margin-bottom:1rem}
