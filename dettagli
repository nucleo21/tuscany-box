<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tuscany Box — Inferno</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#0D0402;--bg2:#1A0804;--bg3:#2A0E06;
  --red:#C0392B;--red2:#E74C3C;--red-dim:#8B2318;
  --gold:#C8860A;--panna:#F5EDD6;--grigio:#9E7E7A;
  --bianco:#FFF8F6;
}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Jost',sans-serif;background:var(--bg);color:var(--panna);overflow-x:hidden}

nav{position:fixed;top:0;left:0;right:0;z-index:100;display:flex;justify-content:space-between;align-items:center;padding:1rem 2.5rem;backdrop-filter:blur(16px);border-bottom:1px solid rgba(255,255,255,.08);transition:all .4s}
.nav-logo{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:700;letter-spacing:-.02em;text-decoration:none}
.nav-logo span{font-style:italic}
.nav-links{display:flex;gap:1.8rem;list-style:none}
.nav-links a{text-decoration:none;font-size:.72rem;font-weight:400;letter-spacing:.12em;text-transform:uppercase;transition:color .3s;opacity:.7}
.nav-links a:hover{opacity:1}
.nav-back{font-size:.72rem;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;opacity:.55;transition:opacity .3s;padding:.45rem .9rem;border:1px solid currentColor;font-family:'Jost',sans-serif}
.nav-back:hover{opacity:1}
@media(max-width:700px){.nav-links{display:none}}

nav{background:rgba(13,4,2,.88);color:var(--panna)}
.nav-logo{color:var(--panna)}.nav-logo span{color:var(--red2)}
.nav-links a{color:var(--panna)}.nav-links a:hover{color:var(--red2)}
.nav-back{color:var(--panna)}

/* HERO */
.hero{
  min-height:100vh;display:flex;flex-direction:column;align-items:center;justify-content:center;
  text-align:center;padding:120px 2rem 5rem;position:relative;overflow:hidden;
  background:radial-gradient(ellipse 70% 60% at 50% 60%,rgba(192,57,43,.18) 0%,transparent 70%),
             radial-gradient(ellipse 100% 50% at 50% 100%,rgba(139,35,24,.3) 0%,transparent 60%),
             linear-gradient(180deg,var(--bg) 0%,var(--bg2) 50%,var(--bg3) 100%);
}
/* ember particles */
.ember{position:absolute;border-radius:50%;pointer-events:none;animation:rise linear infinite}
@keyframes rise{0%{transform:translateY(0) scale(1);opacity:.8}100%{transform:translateY(-100vh) scale(0);opacity:0}}
.hero-dante{font-family:'Cormorant Garamond',serif;font-size:.82rem;font-style:italic;color:rgba(192,57,43,.7);letter-spacing:.18em;text-transform:uppercase;margin-bottom:1.5rem;opacity:0;animation:fadeUp .8s .1s ease forwards}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(4rem,10vw,9rem);line-height:.95;font-weight:700;color:var(--panna);opacity:0;animation:fadeUp .9s .2s ease forwards;letter-spacing:-.02em}
.hero-title em{font-style:italic;color:var(--red2);display:block;font-size:.55em}
.hero-sub{font-family:'Cormorant Garamond',serif;font-size:1.25rem;font-weight:300;line-height:1.9;color:var(--grigio);max-width:520px;margin:1.5rem auto 2.5rem;opacity:0;animation:fadeUp .9s .35s ease forwards}
.hero-quote{font-family:'Playfair Display',serif;font-size:1rem;font-style:italic;color:rgba(192,57,43,.6);margin-bottom:2.5rem;opacity:0;animation:fadeUp .9s .5s ease forwards}
.btn-order{background:var(--red);color:var(--panna);border:none;padding:1rem 2.8rem;font-family:'Jost',sans-serif;font-size:.82rem;font-weight:500;letter-spacing:.18em;text-transform:uppercase;cursor:pointer;transition:all .35s;text-decoration:none;display:inline-block;opacity:0;animation:fadeUp .9s .65s ease forwards}
.btn-order:hover{background:var(--red2);transform:translateY(-3px);box-shadow:0 12px 30px rgba(192,57,43,.4)}
@keyframes fadeUp{from{opacity:0;transform:translateY(24px)}to{opacity:1;transform:translateY(0)}}

/* divider flame */
.flame-divider{display:flex;align-items:center;justify-content:center;gap:1rem;padding:2rem;font-size:1.4rem;opacity:.4}
.flame-line{flex:1;max-width:200px;height:1px;background:linear-gradient(90deg,transparent,var(--red-dim),transparent)}

/* INGREDIENTS */
.ingredients-section{max-width:1000px;margin:0 auto;padding:4rem 2rem 6rem}
.ing-header-section{text-align:center;margin-bottom:3rem}
.ing-tag{font-size:.64rem;letter-spacing:.3em;text-transform:uppercase;color:var(--red2);font-weight:500;margin-bottom:.8rem;display:flex;align-items:center;justify-content:center;gap:.8rem}
.ing-tag::before,.ing-tag::after{content:'';width:24px;height:1px;background:var(--red-dim);display:block}
.ing-section-title{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:600;color:var(--panna);line-height:1.15}
.ing-section-title em{font-style:italic;color:var(--red2)}
.ing-section-desc{font-family:'Cormorant Garamond',serif;font-size:1.05rem;color:var(--grigio);margin-top:.8rem;font-weight:300;line-height:1.8}
.ing-grid{display:flex;flex-direction:column;gap:1.2rem}
.ing-card{
  background:rgba(26,8,4,.6);
  border:1px solid rgba(192,57,43,.15);
  border-left:3px solid var(--red);
  padding:1.8rem 2rem;
  opacity:0;transform:translateY(20px);
  transition:opacity .6s ease, transform .6s ease, border-color .3s, background .3s;
  transition-delay:var(--delay);
}
.ing-card.visible{opacity:1;transform:translateY(0)}
.ing-card:hover{background:rgba(42,14,6,.8);border-left-color:var(--red2)}
.ing-header{display:flex;align-items:center;gap:1rem;margin-bottom:1rem}
.ing-icon{font-size:2.2rem;flex-shrink:0}
.ing-name{font-family:'Playfair Display',serif;font-size:1.15rem;font-weight:600;color:var(--panna);margin-bottom:.2rem}
.ing-origin{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--red2);opacity:.8}
.ing-story{font-family:'Cormorant Garamond',serif;font-size:1.05rem;font-weight:300;line-height:1.9;color:rgba(245,237,214,.65);margin-bottom:1.1rem}
.ing-note{font-size:.82rem;line-height:1.7;color:rgba(245,237,214,.45);padding:.9rem 1rem;background:rgba(192,57,43,.07);border-left:2px solid rgba(192,57,43,.3)}
.ing-note-label{font-weight:500;color:var(--red2);margin-right:.4rem}

/* PAIRING STRIP */
.pairing-strip{background:var(--bg2);border-top:1px solid rgba(192,57,43,.15);border-bottom:1px solid rgba(192,57,43,.15);padding:3rem 2rem;margin:0;text-align:center}
.pairing-title{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:600;color:var(--panna);margin-bottom:.6rem}
.pairing-text{font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:300;color:var(--grigio);line-height:1.85;max-width:680px;margin:0 auto 1.5rem}
.pairing-tags{display:flex;flex-wrap:wrap;gap:.6rem;justify-content:center}
.ptag{background:rgba(192,57,43,.12);border:1px solid rgba(192,57,43,.25);color:var(--panna);font-size:.78rem;padding:.35rem .9rem;letter-spacing:.04em}


footer{padding:3rem 2rem;border-top:1px solid rgba(255,255,255,.07)}
.footer-inner{max-width:1000px;margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:2rem}
.footer-brand{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;margin-bottom:.7rem}
.footer-brand span{font-style:italic}
.footer-tagline{font-family:'Cormorant Garamond',serif;font-size:.88rem;line-height:1.8;opacity:.5}
.fcol-title{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;font-weight:500;margin-bottom:.9rem;opacity:.6}
.footer-links{list-style:none;display:flex;flex-direction:column;gap:.55rem}
.footer-links a{text-decoration:none;font-size:.8rem;opacity:.4;transition:opacity .2s}
.footer-links a:hover{opacity:.9}
.footer-bottom{max-width:1000px;margin:2rem auto 0;padding-top:1.3rem;border-top:1px solid rgba(255,255,255,.06);display:flex;justify-content:space-between;font-size:.7rem;opacity:.35}
@media(max-width:700px){.footer-inner{grid-template-columns:1fr 1fr}}

footer{color:var(--panna)}
.footer-brand span{color:var(--red2)}
.fcol-title{color:var(--red2) !important}

@media(max-width:600px){.ingredients-section{padding:3rem 1.2rem}}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg)}
::-webkit-scrollbar-thumb{background:var(--red);border-radius:2px}
</style>
