<!-- EMBERS -->
<canvas id="ember-canvas" style="position:fixed;inset:0;pointer-events:none;z-index:0;opacity:.5"></canvas>

<section class="hero">
  <div class="hero-dante">Canto I · La Divina Commedia</div>
  <h1 class="hero-title">Inferno<em>Box</em></h1>
  <p class="hero-sub">Sapori intensi e carattere toscano — per chi non ha paura di andare in fondo al gusto.</p>
  <div class="hero-quote">"Per me si va ne la città dolente, per me si va ne l'etterno dolore..."</div>
